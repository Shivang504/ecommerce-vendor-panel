# MongoDB (same database as Admin Panel and storefront)
MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce

# JWT — must match Admin Panel if both apps use the same user/vendor records
JWT_SECRET=change-me-to-a-long-random-string

# Canonical URL for this Vendor Panel
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Optional: forward /api/* browser calls to another origin. Leave unset when this app serves its own /api routes.
# NEXT_PUBLIC_API_BASE_URL=
