# Copy to .env and fill values. Format: KEY=value (no spaces around =)

NODE_ENV=development

NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_BASE_URL=http://localhost:3001

MONGODB_URI=mongodb://127.0.0.1:27017/admin_panel
MONGODB_DB_NAME=admin_panel

JWT_SECRET=change-me-to-a-long-random-string

SHIPROCKET_ENABLED=true
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_API_KEY="your-api-key-with-special-chars"
SHIPROCKET_BASE_URL=https://apiv2.shiprocket.in/v1/external
SHIPROCKET_PICKUP_PINCODE=110001
# Phone/email of verified primary Shiprocket pickup (OTP goes here for new addresses)
SHIPROCKET_VERIFIED_PHONE=7893444131
SHIPROCKET_VERIFIED_EMAIL=your@email.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=support@example.com

# Optional: NEXT_PUBLIC_API_BASE_URL=
